# Block commits with temporary todo markers in staged content.
temp_todos="$(
	git grep --cached -n -E 'FIXME|TODO.*!!' -- \
		':!./.husky/pre-commit' \
		':!./DEVELOPMENT.md' \
		|| :
)"

if [ -n "$temp_todos" ]; then
	printf 'ERROR: temporary todos found in staged content:\n\n%s\n\n' \
		"$temp_todos"
	printf 'Please remove them before committing.\n'
	exit 1
fi

# Run linting first
echo "Running checks..."
pnpm run check

# Running e2e tests
echo "Running e2e tests..."
pnpm build # e2e tests require the plugin to be built first
pnpm run test:e2e